# Anthropic API key for Claude (server-side only)
ANTHROPIC_API_KEY=sk-ant-...

# Solana RPC — use QuickNode for production, mainnet-beta for dev
QUICKNODE_RPC_URL=https://your-endpoint.solana-mainnet.quiknode.pro/...

# Server port (must match vite proxy config in vite.config.ts)
PORT=3001

# Log level for Fastify
LOG_LEVEL=info
