# OpenRouter API key — unified access to Claude/GPT/Gemini/etc.
# Per-project isolation: use KAMI_ prefix so it doesn't clash with shell-wide OPENROUTER_API_KEY
KAMI_OPENROUTER_API_KEY=sk-or-v1-...

# Model ID (via OpenRouter). Default: anthropic/claude-sonnet-4.6
# Swap to anthropic/claude-opus-4.7 or openai/gpt-5 as needed.
KAMI_MODEL=anthropic/claude-sonnet-4.6

# Solana RPC URL — use Helius for free tier, QuickNode/Triton for production
# Fallback is https://api.mainnet-beta.solana.com if unset (rate-limited)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Server port (must match vite proxy config in vite.config.ts)
PORT=3001

# Log level for Fastify
LOG_LEVEL=info
